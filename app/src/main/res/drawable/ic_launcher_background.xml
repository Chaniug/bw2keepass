                android:startX="0" android:startY="0"
                android:endX="108" android:endY="108"
                android:startColor="#23242B"
                android:endColor="#050507" />
        </aapt:attr>
    </path>
    <!-- 左上柔光高光，增加层次 -->
    <path android:pathData="M0,0h108v108H0z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="34" android:centerY="30" android:gradientRadius="70"
                android:startColor="#26FFFFFF"
                android:endColor="#00FFFFFF" />
        </aapt:attr>
    </path>
</vector>
